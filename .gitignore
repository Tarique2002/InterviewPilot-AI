# Root .gitignore

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
dist-ssr/
build/

# Environment variables
.env
.env.local
.env.*.local

# Editor
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.sw?

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
venv/
.venv/
env/

# Database
*.db
*.sqlite
*.sqlite3

# Misc
*.local
*.log
